{% extends 'base.html.twig' %}

{% block title %}Accueil Patient{% endblock %}

{% block body %}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="dashboard">

    <!-- TOP BAR -->
    <div class="top-bar">
        <div class="logo">EMO</div>
        <div class="title">Emonado</div>

        <div class="welcome-box">
            <div class="welcome">Bienvenue, {{ app.user.nom }} {{ app.user.prenom }}</div>
            <div class="subtitle">Tableau de bord</div>
        </div>

    </div>

    <!-- TITLE -->
    <div class="dashboard-title">
        <h1>Bienvenue sur votre espace santé</h1>
        <p>Gérez votre bien-être mental en toute simplicité</p>
    </div>

    <!-- GRID -->
    <div class="dashboard-grid">

        <a href="{{ path('patient_profil') }}" class="card">
            <div class="icon-box profil"><i class="fas fa-user"></i></div>
            <h3>Mon Profil</h3>
            <p>Voir et modifier vos infos</p>
        </a>

        <a href="{{ path('test_page') }}" class="card">
            <div class="icon-box test"><i class="fas fa-clipboard"></i></div>
            <h3>Questionnaire</h3>
            <p>Évaluer votre état mental</p>
        </a>

        <a href="{{ path('app_journal_index') }}" class="card">
            <div class="icon-box journal"><i class="fas fa-pen"></i></div>
            <h3>Mes Journaux</h3>
            <p>Écrire vos pensées</p>
        </a>

        <a href="{{ path('app_rendez_vous_index') }}" class="card">
            <div class="icon-box rdv"><i class="fas fa-calendar"></i></div>
            <h3>Rendez-vous</h3>
            <p>Planifier vos consultations</p>
        </a>

        <a href="{{ path('patient_pre_consultation') }}" class="card card-pay-precon">
            <div class="pay-precon-badge">PAY</div>
            <div class="icon-box precon-pay"><i class="fas fa-credit-card"></i></div>
            <h3>Paiement &amp; questionnaire</h3>
            <p>Payer après acceptation et remplir le dossier clinique</p>
        </a>

        <a href="{{ path('patient_dossier') }}" class="card">
            <div class="icon-box dossier"><i class="fas fa-folder"></i></div>
            <h3>Dossier médical</h3>
            <p>Historique et documents</p>
        </a>

        <a href="{{ path('patient_chatbot') }}" class="card">
            <div class="icon-box pay"><i class="fas fa-comments"></i></div>
            <h3>Chat IA</h3>
            <p>Assistant intelligent</p>
        </a>

        {% if contact %}
            <a href="{{ path('chat', {'id': contact.id}) }}" class="card">
                <div class="icon-box pay"><i class="fas fa-envelope"></i></div>
                <h3>Messagerie</h3>
                <p>Contacter votre psychologue</p>
            </a>
        {% else %}
            <div class="card disabled">
                <div class="icon-box pay"><i class="fas fa-envelope"></i></div>
                <h3>Messagerie</h3>
                <p>Aucun psychologue</p>
            </div>
        {% endif %}

    </div>
</div>

<style>
body {
    margin: 0;
    font-family: "Segoe UI", sans-serif;
    background: linear-gradient(to bottom right, #f0fdf4, #ecfdf5, #f0f9ff);
}

/* TOP BAR */
.top-bar {
    display: flex;
    align-items: center;
    gap: 15px;
    background: white;
    padding: 20px 40px;
    box-shadow: 0 2px 20px rgba(0,0,0,0.06);
}

.logo {
    font-size: 20px;
    font-weight: bold;
    color: #166534;
}

.title {
    font-size: 22px;
    font-weight: bold;
    color: #166534;
}

.welcome-box {
    margin-left: auto;
    text-align: right;
}

.welcome {
    font-size: 15px;
    font-weight: bold;
    color: #1e293b;
}

.subtitle {
    font-size: 12px;
    color: #64748b;
}

/* BUTTONS */
.btn-chatbot {
    background: linear-gradient(to right, #14b8a6, #0ea5e9);
    color: white;
    border: none;
    padding: 10px 18px;
    border-radius: 18px;
    font-weight: bold;
    cursor: pointer;
}

.btn-chat {
    background: linear-gradient(to right, #2563eb, #06b6d4);
    color: white;
    border: none;
    padding: 10px 18px;
    border-radius: 18px;
    font-weight: bold;
    cursor: pointer;
}

/* TITLE */
.dashboard-title {
    text-align: center;
    margin: 30px 0;
}

.dashboard-title h1 {
    font-size: 28px;
    font-weight: bold;
    color: #0f172a;
}

.dashboard-title p {
    font-size: 15px;
    color: #64748b;
}

/* GRID */
.dashboard-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 24px;
    padding: 20px 60px;
}

/* CARD (JAVA FX STYLE EXACT) */
.card {
    width: 210px;
    height: 200px;
    background: white;
    border-radius: 24px;
    padding: 25px 20px;
    text-align: center;
    box-shadow: 0 8px 25px rgba(0,0,0,0.08);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    transition: 0.3s;
}

.card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 30px rgba(0,0,0,0.12);
}

/* ICON BOX */
.icon-box {
    width: 60px;
    height: 60px;
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
}

/* COLORS EXACT JAVAFX */
.profil { background: linear-gradient(to bottom right, #dcfce7, #bbf7d0); }
.test { background: linear-gradient(to bottom right, #fef3c7, #fde68a); }
.journal { background: linear-gradient(to bottom right, #e0e7ff, #c7d2fe); }
.rdv { background: linear-gradient(to bottom right, #fce7f3, #fbcfe8); }
.dossier { background: linear-gradient(to bottom right, #ccfbf1, #99f6e4); }
.pay { background: linear-gradient(to bottom right, #dbeafe, #bfdbfe); }
.precon-pay { background: linear-gradient(to bottom right, #7dd3fc, #38bdf8); }

.card-pay-precon {
    position: relative;
    padding-top: 20px;
}
.pay-precon-badge {
    position: absolute;
    top: 14px;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(to right, #38bdf8, #0ea5e9);
    color: #fff;
    font-weight: 800;
    font-size: 13px;
    letter-spacing: 0.12em;
    padding: 8px 28px;
    border-radius: 14px;
    box-shadow: 0 4px 14px rgba(14, 165, 233, 0.45);
}
.card-pay-precon .icon-box {
    margin-top: 28px;
}

/* TEXT */
.card h3 {
    font-size: 16px;
    font-weight: bold;
    color: #1e293b;
    margin: 5px 0;
}

.card p {
    font-size: 12px;
    color: #94a3b8;
}

/* DISABLED */
.card.disabled {
    opacity: 0.6;
    pointer-events: none;
}
</style>

{% endblock %}