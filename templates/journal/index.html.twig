{% extends 'base.html.twig' %}

{% block title %}Mes Journaux{% endblock %}

{% block body %}
<style>
    .mood-card {
        background: linear-gradient(135deg, #e3f2fd 0%, #f3e5f5 100%);
        border-radius: 14px;
        padding: 16px;
        text-align: center;
        margin-bottom: 16px;
    }
    .mood-card.heureux { background: linear-gradient(135deg, #e8f5e8 0%, #f1f8e9 100%); }
    .mood-card.calme { background: linear-gradient(135deg, #e0f2f1 0%, #e8f5e8 100%); }
    .mood-card.sos { background: linear-gradient(135deg, #fff3e0 0%, #fff8e1 100%); }
    .mood-card.colere { background: linear-gradient(135deg, #ffebee 0%, #fce4ec 100%); }
    .mood-count { font-size: 22px; font-weight: bold; color: #143d2d; }
    .mood-label { font-size: 16px; font-weight: bold; color: #284354; }
    .pro-card {
        background: white;
        border-radius: 14px;
        padding: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    .pro-title { font-size: 18px; font-weight: bold; color: #116b46; margin-bottom: 12px; }
    .progress-bar-custom {
        height: 20px;
        border-radius: 10px;
    }
    .tab-content { padding: 20px 0; }
</style>

<div style="background: linear-gradient(to bottom, #8fd9ee 0%, #dff7ff 100%); min-height: 100vh; padding: 24px;">
    <div style="max-width: 1200px; margin: 0 auto;">
        <h1 style="font-size: 30px; font-weight: bold; color: #116b46; text-align: center; margin-bottom: 24px;">Mes journaux</h1>

        <!-- Mood Counts -->
        <div style="display: flex; gap: 16px; margin-bottom: 24px;">
            <div class="mood-card heureux" style="flex: 1;">
                <div class="mood-label">Heureux</div>
                <div class="mood-count" id="heureuxCount">{{ stats['heureux'] ?? 0 }}</div>
            </div>
            <div class="mood-card calme" style="flex: 1;">
                <div class="mood-label">Calme</div>
                <div class="mood-count" id="calmeCount">{{ stats['calme'] ?? 0 }}</div>
            </div>
            <div class="mood-card sos" style="flex: 1;">
                <div class="mood-label">SOS</div>
                <div class="mood-count" id="sosCount">{{ stats['SOS'] ?? 0 }}</div>
            </div>
            <div class="mood-card colere" style="flex: 1;">
                <div class="mood-label">En colère</div>
                <div class="mood-count" id="colereCount">{{ stats['en colere'] ?? 0 }}</div>
            </div>
        </div>

        <!-- Search and Export -->
        <div style="display: flex; gap: 12px; margin-bottom: 24px; align-items: center;">
            <input type="text" id="searchField" value="{{ keyword }}" class="form-control" placeholder="Rechercher par humeur ou contenu" style="flex: 1;">
            <select id="sortCombo" class="form-select" style="width: 180px;">
                <option value="recent" {{ sort != 'old' ? 'selected' : '' }}>Plus récent</option>
                <option value="old" {{ sort == 'old' ? 'selected' : '' }}>Plus ancien</option>
            </select>
            <a href="{{ path('app_journal_pdf') }}" class="btn btn-success" style="background-color: #1f8b57; border: none; border-radius: 12px; padding: 10px 18px; font-weight: bold;">
                <i class="fa-solid fa-file-pdf"></i> Exporter PDF
            </a>
        </div>

        <!-- Tabs -->
        <div class="pro-card">
            <ul class="nav nav-tabs" id="journalTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="gestion-tab" data-bs-toggle="tab" data-bs-target="#gestion" type="button" role="tab">Gestion journal</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="statistiques-tab" data-bs-toggle="tab" data-bs-target="#statistiques" type="button" role="tab">Statistiques pro</button>
                </li>
            </ul>
            <div class="tab-content" id="journalTabsContent">
                <!-- Gestion Tab -->
                <div class="tab-pane fade show active" id="gestion" role="tabpanel">
                    <div style="display: flex; gap: 18px; margin-top: 20px;">
                        <!-- New Journal Form -->
                        <div style="flex: 1; max-width: 330px;">
                            <div class="pro-card">
                                <div class="pro-title">Nouveau journal</div>
                                <form id="newJournalForm" method="post" action="{{ path('app_journal_new') }}">
                                    <div class="mb-3">
                                        <label class="form-label">Humeur</label>
                                        <select name="journal[humeur]" class="form-select" required>
                                            <option value="">Sélectionnez une humeur</option>
                                            <option value="heureux">Heureux</option>
                                            <option value="calme">Calme</option>
                                            <option value="SOS">SOS</option>
                                            <option value="en colere">En colère</option>
                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Contenu</label>
                                        <textarea name="journal[contenu]" class="form-control" rows="12" placeholder="Écrivez votre journal ici..." required></textarea>
                                    </div>
                                    <input type="hidden" name="journal[_token]" value="{{ csrf_token('journal') }}">
                                    <button type="submit" class="btn btn-success w-100" style="background-color: #1f8b57; border: none;">Ajouter</button>
                                </form>
                            </div>
                        </div>

                        <!-- Journal List -->
                        <div style="flex: 1;">
                            <div class="pro-card">
                                <div class="pro-title">Liste des journaux</div>
                                <div style="display: flex; gap: 10px; margin-bottom: 12px;">
                                    <button id="editBtn" class="btn btn-primary" disabled>Modifier</button>
                                    <button id="deleteBtn" class="btn btn-danger" disabled>Supprimer</button>
                                </div>
                                <div class="table-responsive">
                                    <table class="table table-hover" id="journalTable">
                                        <thead>
                                            <tr>
                                                <th>Humeur</th>
                                                <th>Contenu</th>
                                                <th>Date</th>
                                                <th>Analyse</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% for journal in journals %}
                                            <tr data-id="{{ journal.id }}" data-humeur="{{ journal.humeur }}" data-contenu="{{ journal.contenu }}"
                                                data-delete-url="{{ path('app_journal_delete', {id: journal.id}) }}"
                                                data-delete-token="{{ csrf_token('delete' ~ journal.id) }}">
                                                <td>{% if journal.humeur == 'SOS' %}SOS{% elseif journal.humeur == 'en colere' %}En colère{% else %}{{ journal.humeur|capitalize }}{% endif %}</td>
                                                <td>{{ journal.contenu|slice(0, 50) }}{% if journal.contenu|length > 50 %}...{% endif %}</td>
                                                <td>{{ journal.dateCreation|date('d/m/Y H:i') }}</td>
                                                <td>{% if journal.analysisEmotionnelle %}Disponible{% else %}Aucune{% endif %}</td>
                                            </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Statistiques Tab -->
                <div class="tab-pane fade" id="statistiques" role="tabpanel">
                    <div style="margin-top: 20px;">
                        <div style="display: flex; gap: 16px; margin-bottom: 24px;">
                            <div class="pro-card" style="flex: 1;">
                                <div style="font-size: 13px; font-weight: bold; color: #25554f;">Total journaux</div>
                                <div style="font-size: 24px; font-weight: bold; color: #134a39;">{{ journals|length }}</div>
                            </div>
                            <div class="pro-card" style="flex: 1;">
                                <div style="font-size: 13px; font-weight: bold; color: #25554f;">Analyses disponibles</div>
                                <div style="font-size: 24px; font-weight: bold; color: #134a39;">{{ analysedCount }}</div>
                            </div>
                            <div class="pro-card" style="flex: 1;">
                                <div style="font-size: 13px; font-weight: bold; color: #25554f;">Sans analyse</div>
                                <div style="font-size: 24px; font-weight: bold; color: #134a39;">{{ journals|length - analysedCount }}</div>
                            </div>
                        </div>

                        <div class="pro-card">
                            <div class="pro-title">Distribution des humeurs</div>
                            {% set total = journals|length %}
                            {% set heureuxPercent = total > 0 ? (stats['heureux'] / total * 100)|round(1) : 0 %}
                            {% set calmePercent = total > 0 ? (stats['calme'] / total * 100)|round(1) : 0 %}
                            {% set sosPercent = total > 0 ? (stats['SOS'] / total * 100)|round(1) : 0 %}
                            {% set colerePercent = total > 0 ? (stats['en colere'] / total * 100)|round(1) : 0 %}

                            <div style="display: flex; align-items: center; margin-bottom: 10px;">
                                <div style="width: 110px;">Heureux</div>
                                <div class="progress" style="flex: 1; height: 20px;">
                                    <div class="progress-bar bg-success" style="width: {{ heureuxPercent }}%"></div>
                                </div>
                                <div style="width: 70px; text-align: right;">{{ heureuxPercent }}% ({{ stats['heureux'] ?? 0 }})</div>
                            </div>
                            <div style="display: flex; align-items: center; margin-bottom: 10px;">
                                <div style="width: 110px;">Calme</div>
                                <div class="progress" style="flex: 1; height: 20px;">
                                    <div class="progress-bar bg-info" style="width: {{ calmePercent }}%"></div>
                                </div>
                                <div style="width: 70px; text-align: right;">{{ calmePercent }}% ({{ stats['calme'] ?? 0 }})</div>
                            </div>
                            <div style="display: flex; align-items: center; margin-bottom: 10px;">
                                <div style="width: 110px;">SOS</div>
                                <div class="progress" style="flex: 1; height: 20px;">
                                    <div class="progress-bar bg-warning" style="width: {{ sosPercent }}%"></div>
                                </div>
                                <div style="width: 70px; text-align: right;">{{ sosPercent }}% ({{ stats['SOS'] ?? 0 }})</div>
                            </div>
                            <div style="display: flex; align-items: center; margin-bottom: 10px;">
                                <div style="width: 110px;">En colère</div>
                                <div class="progress" style="flex: 1; height: 20px;">
                                    <div class="progress-bar bg-danger" style="width: {{ colerePercent }}%"></div>
                                </div>
                                <div style="width: 70px; text-align: right;">{{ colerePercent }}% ({{ stats['en colere'] ?? 0 }})</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Modifier le journal</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="editJournalForm" method="post">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Humeur</label>
                        <select name="journal[humeur]" id="editHumeur" class="form-select" required>
                            <option value="heureux">Heureux</option>
                            <option value="calme">Calme</option>
                            <option value="SOS">SOS</option>
                            <option value="en colere">En colère</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Contenu</label>
                        <textarea name="journal[contenu]" id="editContenu" class="form-control" rows="8" required></textarea>
                    </div>
                    <input type="hidden" name="journal[_token]" id="editToken">
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-primary">Modifier</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const searchField = document.getElementById('searchField');
    const sortCombo = document.getElementById('sortCombo');
    const journalTable = document.getElementById('journalTable');
    const editBtn = document.getElementById('editBtn');
    const deleteBtn = document.getElementById('deleteBtn');
    const editModal = new bootstrap.Modal(document.getElementById('editModal'));
    let selectedRow = null;

    // Table row selection
    journalTable.addEventListener('click', function(e) {
        const row = e.target.closest('tr');
        if (row && row.dataset.id) {
            if (selectedRow) selectedRow.classList.remove('table-active');
            row.classList.add('table-active');
            selectedRow = row;
            editBtn.disabled = false;
            deleteBtn.disabled = false;
        }
    });

    // Edit button
    editBtn.addEventListener('click', function() {
        if (!selectedRow) return;
        document.getElementById('editHumeur').value = selectedRow.dataset.humeur;
        document.getElementById('editContenu').value = selectedRow.dataset.contenu;
        document.getElementById('editJournalForm').action = '/journal/' + selectedRow.dataset.id + '/edit';
        document.getElementById('editToken').value = '{{ csrf_token('journal') }}';
        editModal.show();
    });

    // Delete button
    deleteBtn.addEventListener('click', function() {
        if (!selectedRow) return;
        if (confirm('Voulez-vous vraiment supprimer ce journal ?')) {
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = selectedRow.dataset.deleteUrl;
            const token = document.createElement('input');
            token.type = 'hidden';
            token.name = '_token';
            token.value = selectedRow.dataset.deleteToken;
            form.appendChild(token);
            document.body.appendChild(form);
            form.submit();
        }
    });

    // Search and sort
    function applyFilters() {
        const keyword = searchField.value.toLowerCase();
        const sortOrder = sortCombo.value;
        const rows = Array.from(journalTable.querySelectorAll('tbody tr'));

        rows.forEach(row => {
            const humeur = row.cells[0].textContent.toLowerCase();
            const contenu = row.cells[1].textContent.toLowerCase();
            const visible = !keyword || humeur.includes(keyword) || contenu.includes(keyword);
            row.style.display = visible ? '' : 'none';
        });

        // Sort
        const tbody = journalTable.querySelector('tbody');
        const sortedRows = rows.filter(row => row.style.display !== 'none').sort((a, b) => {
            const dateA = new Date(a.cells[2].textContent.split('/').reverse().join('-'));
            const dateB = new Date(b.cells[2].textContent.split('/').reverse().join('-'));
            return sortOrder === 'recent' ? dateB - dateA : dateA - dateB;
        });
        sortedRows.forEach(row => tbody.appendChild(row));
    }

    searchField.addEventListener('input', applyFilters);
    sortCombo.addEventListener('change', applyFilters);
});
</script>
{% endblock %}
