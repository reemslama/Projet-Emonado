{% extends 'base.html.twig' %}

{% block title %}Créer un compte{% endblock %}

{% block stylesheets %}
<style>
body {
    background-color: #f8f8f8;
    font-family: 'Segoe UI', sans-serif;
}

.card {
    background: white !important;
    border-radius: 25px !important;
    padding: 20px;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1) !important;
    border: none !important;
}

.card-header {
    background: transparent !important;
    border-bottom: none !important;
    text-align: center;
    padding-bottom: 10px;
}

.card-header h3 {
    font-size: 26px;
    font-weight: bold;
    color: #333 !important;
    margin-bottom: 5px;
}

.subtitle {
    text-align: center;
    color: #777;
    font-size: 14px;
    margin-bottom: 25px;
}

.form-control,
.form-select {
    border-radius: 15px !important;
    padding: 12px !important;
    border: 1px solid #ddd !important;
    box-shadow: none !important;
    transition: all 0.3s ease;
}

.form-control:focus,
.form-select:focus {
    border-color: #c5df43 !important;
    box-shadow: 0 0 5px rgba(197,223,67,0.4) !important;
}

.form-label {
    font-weight: 500;
    color: #555;
}

.form-check-label {
    color: #555;
    font-size: 13px;
}

.btn-success,
.btn-custom {
    background-color: #c5df43 !important;
    border: none !important;
    color: white !important;
    border-radius: 20px !important;
    font-size: 16px !important;
    font-weight: bold !important;
    padding: 12px !important;
    transition: 0.3s ease;
}

.btn-success:hover,
.btn-custom:hover {
    background-color: #b2cc35 !important;
    transform: scale(1.02);
}

.btn-outline-primary {
    border-radius: 20px !important;
    border: 2px solid #c5df43 !important;
    color: #c5df43 !important;
    font-weight: bold;
}

.btn-outline-primary:hover {
    background-color: #c5df43 !important;
    color: white !important;
}

.alert-danger {
    border-radius: 15px;
    font-size: 14px;
}

.password-info {
    color: #999;
    font-size: 10px;
    margin-top: -10px;
    margin-bottom: 15px;
}

@media (max-width: 768px) {
    .card {
        padding: 25px 15px;
    }

    .card-header h3 {
        font-size: 22px;
    }
}
</style>
{% endblock %}

{% block body %}
<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow-lg">

            <div class="card-header">
                <h3>Créer un compte</h3>
                <p class="subtitle">Remplissez vos informations</p>
            </div>

            <div class="card-body p-4">

                {% if errors|length > 0 %}
                    <div class="alert alert-danger">
                        <ul class="mb-0 list-unstyled">
                            {% for message in errors %}
                                <li>{{ message }}</li>
                            {% endfor %}
                        </ul>
                    </div>
                {% endif %}

                <form method="post" novalidate>
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('register') }}">

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <input type="text" name="nom" id="nom" class="form-control"
                                   placeholder="Nom"
                                   value="{{ formData.nom|default('') }}">
                        </div>

                        <div class="col-md-6 mb-3">
                            <input type="text" name="prenom" id="prenom" class="form-control"
                                   placeholder="Prénom"
                                   value="{{ formData.prenom|default('') }}">
                        </div>
                    </div>

                    <div class="mb-3">
                        <input type="email" name="email" id="email" class="form-control"
                               placeholder="Email"
                               value="{{ formData.email|default('') }}"
                               autocomplete="email" required>
                    </div>

                    <div class="mb-3">
                        <input type="password" name="password" id="password"
                               class="form-control"
                               placeholder="Mot de passe"
                               autocomplete="new-password">
                    </div>

                    <div class="password-info">
                        8 caractères min (1 majuscule, 1 chiffre, 1 spécial)
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <input type="text" name="telephone" id="telephone"
                                   class="form-control"
                                   placeholder="Téléphone"
                                   value="{{ formData.telephone|default('') }}">
                        </div>

                        <div class="col-md-6 mb-3">
                            <select name="sexe" id="sexe" class="form-select">
                                <option value="">Sexe</option>
                                <option value="Homme"
                                    {{ formData.sexe|default('') == 'Homme' ? 'selected' : '' }}>
                                    Homme
                                </option>
                                <option value="Femme"
                                    {{ formData.sexe|default('') == 'Femme' ? 'selected' : '' }}>
                                    Femme
                                </option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <input type="date" name="date_naissance" id="date_naissance"
                               class="form-control"
                               value="{{ formData.date_naissance|default('') }}">
                    </div>

                    <div class="mb-3 form-check">
                        <input type="checkbox"
                               name="hasChild"
                               id="hasChild"
                               class="form-check-input"
                               {{ formData.hasChild|default(false) ? 'checked' : '' }}>

                        <label class="form-check-label" for="hasChild">
                            J'ai un ou plusieurs enfants
                        </label>
                    </div>
                    <div class="d-grid mb-3">
                        <button class="btn btn-success btn-lg btn-custom">
                            Créer mon compte
                        </button>
                    </div>
                </form>

                <div class="text-center">
                    <p>Vous avez déjà un compte ?</p>
                    <a href="{{ path('app_login') }}" class="btn btn-outline-primary btn-custom">
                        Se connecter
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>
{% endblock %}