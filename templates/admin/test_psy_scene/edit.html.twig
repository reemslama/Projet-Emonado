{% extends 'base_admin.html.twig' %}

{% block title %}Modifier Scène Enfant{% endblock %}

{% block header %}Modifier la Scène #{{ scene.numero }}{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-warning text-dark p-4 rounded-top-4">
                <h5 class="mb-0"><i class="bi bi-pencil me-2"></i> Modifier les Informations</h5>
            </div>
            <div class="card-body p-4">
                {{ form_start(form) }}
                    <div class="mb-3">
                        {{ form_label(form.numero) }}
                        {{ form_widget(form.numero) }}
                    </div>
                    <div class="mb-3">
                        {{ form_label(form.type) }}
                        {{ form_widget(form.type) }}
                    </div>
                    <div class="mb-3">
                        {{ form_label(form.titre) }}
                        {{ form_widget(form.titre) }}
                    </div>
                    <div class="mb-3">
                        {{ form_label(form.imagePath) }}
                        {{ form_widget(form.imagePath) }}
                        <small class="text-muted">Nom du fichier actuel : {{ scene.imagePath|default('Aucun') }}</small>
                    </div>
                    <div class="mb-3">
                        {{ form_label(form.descriptionPsy) }}
                        {{ form_widget(form.descriptionPsy) }}
                    </div>
                    <div class="mb-4">
                        {{ form_widget(form.actif) }}
                        {{ form_label(form.actif) }}
                    </div>

                    <div class="d-flex justify-content-between">
                        <a href="{{ path('admin_test_psy_scene_index') }}" class="btn btn-secondary rounded-pill px-4">
                            <i class="bi bi-arrow-left me-2"></i> Retour
                        </a>
                        <button class="btn btn-primary rounded-pill px-4">
                            <i class="bi bi-save me-2"></i> Enregistrer
                        </button>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
