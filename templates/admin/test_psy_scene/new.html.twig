{% extends 'base_admin.html.twig' %}

{% block title %}Nouvelle Scène Enfant{% endblock %}

{% block header %}Ajouter une Scène{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-primary text-white p-4 rounded-top-4">
                <h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i> Informations de la Scène</h5>
            </div>
            <div class="card-body p-4">
                {{ form_start(form) }}
                    <div class="mb-3">
                        {{ form_label(form.numero) }}
                        {{ form_widget(form.numero) }}
                    </div>
                    <div class="mb-3">
                        {{ form_label(form.type) }}
                        {{ form_widget(form.type) }}
                    </div>
                    <div class="mb-3">
                        {{ form_label(form.titre) }}
                        {{ form_widget(form.titre) }}
                    </div>
                    <div class="mb-3">
                        {{ form_label(form.imagePath) }}
                        {{ form_widget(form.imagePath) }}
                        <small class="text-muted">Nom du fichier dans le dossier assets/images.</small>
                    </div>
                    <div class="mb-3">
                        {{ form_label(form.descriptionPsy) }}
                        {{ form_widget(form.descriptionPsy) }}
                    </div>
                    <div class="mb-4">
                        {{ form_widget(form.actif) }}
                        {{ form_label(form.actif) }}
                    </div>

                    {# ===== SECTION RÉPONSES ===== #}
                    <hr>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-bold text-primary mb-0"><i class="bi bi-list-check me-2"></i>Réponses de la Scène</h6>
                        <button type="button" class="btn btn-sm btn-outline-primary rounded-pill" id="add-reponse">
                            <i class="bi bi-plus-lg me-1"></i> Ajouter une réponse
                        </button>
                    </div>

                    <div id="reponses-collection" 
                         data-prototype="{{ form_widget(form.reponses.vars.prototype)|e('html_attr') }}"
                         data-index="{{ form.reponses|length }}">
                        {% for reponseForm in form.reponses %}
                            <div class="reponse-item card border mb-3 rounded-3">
                                <div class="card-body p-3">
                                    <div class="d-flex justify-content-end mb-2">
                                        <button type="button" class="btn btn-sm btn-outline-danger rounded-pill remove-reponse">
                                            <i class="bi bi-trash"></i> Supprimer
                                        </button>
                                    </div>
                                    <div class="row g-2">
                                        <div class="col-md-4">{{ form_label(reponseForm.label) }}{{ form_widget(reponseForm.label) }}</div>
                                        <div class="col-md-2">{{ form_label(reponseForm.emoji) }}{{ form_widget(reponseForm.emoji) }}</div>
                                        <div class="col-md-3">{{ form_label(reponseForm.imagePath) }}{{ form_widget(reponseForm.imagePath) }}</div>
                                        <div class="col-md-3">{{ form_label(reponseForm.etatDesc) }}{{ form_widget(reponseForm.etatDesc) }}</div>
                                        <div class="col-md-3">{{ form_label(reponseForm.poidsAnxiete) }}{{ form_widget(reponseForm.poidsAnxiete) }}</div>
                                        <div class="col-md-3">{{ form_label(reponseForm.poidsTristesse) }}{{ form_widget(reponseForm.poidsTristesse) }}</div>
                                        <div class="col-md-3">{{ form_label(reponseForm.poidsColere) }}{{ form_widget(reponseForm.poidsColere) }}</div>
                                        <div class="col-md-3">{{ form_label(reponseForm.poidsJoie) }}{{ form_widget(reponseForm.poidsJoie) }}</div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                    {# ===== FIN SECTION RÉPONSES ===== #}

                    <div class="d-flex justify-content-between mt-3">
                        <a href="{{ path('admin_test_psy_scene_index') }}" class="btn btn-secondary rounded-pill px-4">
                            <i class="bi bi-arrow-left me-2"></i> Retour
                        </a>
                        <button class="btn btn-success rounded-pill px-4">
                            <i class="bi bi-check-lg me-2"></i> Créer la scène
                        </button>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const container = document.getElementById('reponses-collection');
    let index = parseInt(container.dataset.index);

    document.getElementById('add-reponse').addEventListener('click', function () {
        const prototype = container.dataset.prototype;
        const newForm = prototype.replace(/__name__/g, index);
        index++;
        container.dataset.index = index;

        const div = document.createElement('div');
        div.classList.add('reponse-item', 'card', 'border', 'mb-3', 'rounded-3');
        div.innerHTML = `
            <div class="card-body p-3">
                <div class="d-flex justify-content-end mb-2">
                    <button type="button" class="btn btn-sm btn-outline-danger rounded-pill remove-reponse">
                        <i class="bi bi-trash"></i> Supprimer
                    </button>
                </div>
                <div class="row g-2">${newForm}</div>
            </div>`;
        container.appendChild(div);
        div.querySelector('.remove-reponse').addEventListener('click', function () {
            div.remove();
        });
    });

    document.querySelectorAll('.remove-reponse').forEach(function (btn) {
        btn.addEventListener('click', function () {
            btn.closest('.reponse-item').remove();
        });
    });
});
</script>
{% endblock %}
