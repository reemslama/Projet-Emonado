{% extends 'base_admin.html.twig' %}

{% block title %}Gestion des Patients{% endblock %}

{% block header %}Patients{% endblock %}

{% block body %}
<div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-primary text-white p-4 rounded-top-4">
        <div class="d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold"><i class="bi bi-people-fill me-2"></i> Liste des Patients</h5>
            <a href="{{ path('admin_user_add') }}" class="btn btn-light rounded-pill btn-sm fw-bold">
                <i class="bi bi-person-plus me-1"></i> Ajouter
            </a>
        </div>
    </div>
    <div class="card-body p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Nom</th>
                        <th>Prénom</th>
                        <th>Email</th>
                        <th>Téléphone</th>
                        <th>Dossier</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for patient in patients %}
                    <tr>
                        <td class="fw-bold">{{ patient.nom }}</td>
                        <td>{{ patient.prenom }}</td>
                        <td>{{ patient.email }}</td>
                        <td>{{ patient.telephone ?? 'N/A' }}</td>
                        <td>
                            {% if dossiersParPatient[patient.id] is defined %}
                                <span class="badge bg-success rounded-pill">Actif</span>
                            {% else %}
                                <span class="badge bg-secondary rounded-pill">Aucun</span>
                            {% endif %}
                        </td>
                        <td>
                            <div class="btn-group">
                                <a href="{{ path('admin_user_edit', {id: patient.id}) }}" class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil"></i></a>
                                <form method="post" action="{{ path('admin_user_delete', {id: patient.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer ce patient ?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ patient.id) }}">
                                    <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="6" class="text-center py-4">Aucun patient trouvé.</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
